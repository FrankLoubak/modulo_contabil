# Banco de dados (porta 5440 no host — ver docker-compose.yml)
DATABASE_URL=postgres://postgres:postgres@localhost:5440/saas_contabil_dev

# Redis
REDIS_URL=redis://localhost:6390

# JWT — gerar segredo forte: openssl rand -hex 32
JWT_SECRET=trocar-por-segredo-forte

# Servidor
PORT=3333
HOST=0.0.0.0

# NFE.io — Sprint A2 (emissão, consulta de CNPJ, distribuição de entradas)
# NFEIO_ENVIRONMENT: production | sandbox
NFEIO_ENVIRONMENT=sandbox
NFEIO_API_KEY=
# companyId do emitente na NFE.io (1 por tenant — aqui só o default de dev)
NFEIO_COMPANY_ID=
